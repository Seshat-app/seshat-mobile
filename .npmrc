# expo-router transitively pulls in react-dom@19.2.6 which requires
# react@^19.2.6, but expo SDK 54 ships with react@19.1.0. The peer mismatch
# is harmless in practice (no real ABI break) but blocks strict npm ci.
# This flag makes both local npm install AND EAS Build's npm ci tolerate it.
legacy-peer-deps=true
